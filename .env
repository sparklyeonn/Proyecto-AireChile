# Configuración general
PROJECT_NAME=AireChile Analytics
LOG_LEVEL=INFO

# Ruta del archivo SINCA descargado
# Cambia el nombre por el archivo real que guardes en data/raw/
SINCA_RAW_PATH=data/raw/sinca_puente_alto_mp25_2022_2026.csv

# Carpeta donde se guardará el reporte generado
SINCA_REPORT_PATH=docs/reporte_columnas_sinca.md

# API meteorológica Open-Meteo
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# Coordenadas Santiago de Chile
SANTIAGO_LAT=-33.4489
SANTIAGO_LON=-70.6693

# Base de datos PostgreSQL, para etapas posteriores
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=airechile
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres